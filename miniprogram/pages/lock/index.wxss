.calculator-screen {
  min-height: 100vh;
  background: #000000;
  color: #ffffff;
  box-sizing: border-box;
  padding: 22rpx 28rpx 34rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.top-safe {
  position: fixed;
  top: 28rpx;
  right: 24rpx;
  z-index: 2;
}

.logout {
  min-width: 92rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  padding: 0 20rpx;
}

.display-block {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-end;
  padding: 0 16rpx 28rpx;
  box-sizing: border-box;
}

.hint {
  max-width: 100%;
  color: #ff9f0a;
  font-size: 26rpx;
  margin-bottom: 22rpx;
  text-align: right;
}

.display {
  width: 100%;
  color: #ffffff;
  font-size: 108rpx;
  font-weight: 200;
  line-height: 1.05;
  text-align: right;
  word-break: break-all;
}

.result {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.56);
  font-size: 30rpx;
}

.verifying {
  height: 560rpx;
  color: #ff9f0a;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 159, 10, 0.25);
  border-top-color: #ff9f0a;
}

.keypad {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.calc-row {
  display: flex;
  gap: 24rpx;
}

.key {
  flex: 1;
  height: 156rpx;
  border-radius: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  font-weight: 300;
  line-height: 1;
  user-select: none;
}

.key.utility {
  background: #a5a5a5;
  color: #000000;
  font-size: 48rpx;
}

.key.operator {
  background: #ff9f0a;
  color: #ffffff;
}

.key.number {
  background: #333333;
  color: #ffffff;
}

.key.wide {
  flex: 2;
  justify-content: flex-start;
  padding-left: 58rpx;
  box-sizing: border-box;
}
