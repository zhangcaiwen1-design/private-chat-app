.chat-screen {
  min-height: 100vh;
  background: #ededed;
  box-sizing: border-box;
  padding-top: 0;
  display: flex;
  flex-direction: column;
}

.chat-header {
  min-height: 100rpx;
  padding: 12rpx 16rpx 10rpx 16rpx;
  background: #f7f7f7;
  border-bottom: 1rpx solid #d8d8d8;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.header-icon {
  color: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-icon.small {
  width: 64rpx;
  height: 64rpx;
}

.header-center {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 0 16rpx;
}

.chat-title {
  display: block;
  color: #111111;
  font-size: 32rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-subtitle {
  display: block;
  color: #8c8c8c;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.message-list {
  flex: 1;
  padding: 20rpx 12rpx 280rpx;
  box-sizing: border-box;
}

.message-row {
  display: flex;
  margin: 8rpx 0;
  align-items: flex-end;
}

.message-row.mine {
  justify-content: flex-end;
}

.message-row.theirs {
  justify-content: flex-start;
}

.bubble {
  max-width: 72%;
  padding: 10rpx 12rpx;
  border-radius: 10rpx;
  line-height: 1.5;
  word-break: break-word;
  background: #ffffff;
}

.message-row.mine .bubble {
  background: #95ec69;
}

.message-row.mine .sticker-bubble,
.message-row.mine .image-bubble {
  background: transparent;
}

.text-message {
  color: #111111;
  font-size: 28rpx;
}

.image-bubble {
  padding: 0;
}

.image-message {
  width: 280rpx;
  height: 220rpx;
  border-radius: 12rpx;
  display: block;
}

.sticker-bubble {
  min-width: 120rpx;
  text-align: center;
  background: transparent;
  padding: 0;
}

.sticker-message {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
}

.sticker-emoji {
  font-size: 64rpx;
  line-height: 1;
}

.voice-message {
  min-width: 160rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #111111;
}

.voice-icon {
  color: #07c160;
  font-size: 30rpx;
}

.empty {
  color: #8c8c8c;
  font-size: 26rpx;
  text-align: center;
  padding: 60rpx 24rpx;
}

.error {
  display: block;
  padding: 0 24rpx 10rpx;
  color: #c34d3e;
  font-size: 24rpx;
}

.input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 12rpx 16rpx 16rpx;
  background: #f7f7f7;
  border-top: 1rpx solid #d8d8d8;
  box-sizing: border-box;
}

.round-icon {
  color: #666666;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 76rpx;
  height: 76rpx;
}

.input-wrap {
  flex: 1;
  min-height: 76rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.message-input {
  width: 100%;
  min-height: 76rpx;
  font-size: 28rpx;
  color: #111111;
}

.voice-press {
  width: 100%;
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333333;
  font-size: 28rpx;
  font-weight: 500;
}

.voice-press.active {
  color: #111111;
  background: #f1f1f1;
  border-radius: 12rpx;
}

.send-button {
  min-width: 100rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #95ec69;
  color: #20330f;
  font-size: 26rpx;
  font-weight: 600;
}

.recording-toast {
  position: fixed;
  left: 50%;
  bottom: 170rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.78);
  color: #ffffff;
  font-size: 24rpx;
}

.record-dot {
  color: #ff5b5b;
}

.more-panel {
  position: fixed;
  left: 0;
  right: 0;
  padding: 22rpx 18rpx 28rpx;
  background: #f7f7f7;
  border-top: 1rpx solid #d8d8d8;
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.more-item {
  width: 144rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #585858;
  font-size: 22rpx;
}

.more-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
}

.sticker-panel {
  position: fixed;
  left: 0;
  right: 0;
  padding: 18rpx 18rpx 28rpx;
  background: #f7f7f7;
  border-top: 1rpx solid #d8d8d8;
  box-sizing: border-box;
}

.sticker-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.sticker-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 6rpx;
  border-radius: 0;
  background: transparent;
}

.sticker-pick-emoji {
  font-size: 44rpx;
}

.sticker-pick-label {
  font-size: 22rpx;
  color: #6b6b6b;
}

.placeholder {
  color: #9b9b9b;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.msg-avatar.other {
  background: #ddebff;
  color: #2753a6;
  margin-right: 8rpx;
}

.msg-avatar.mine {
  background: #95ec69;
  color: #213011;
  margin-left: 8rpx;
}

.line-icon {
  position: relative;
  display: inline-block;
  box-sizing: border-box;
  color: currentColor;
}

.icon-back {
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  transform: rotate(45deg);
  margin-left: 3rpx;
}

.icon-lock {
  width: 16rpx;
  height: 12rpx;
  border: 2.5rpx solid currentColor;
  border-radius: 4rpx;
}

.icon-lock::before {
  content: '';
  position: absolute;
  left: 3rpx;
  top: -6rpx;
  width: 8rpx;
  height: 6rpx;
  border: 2.5rpx solid currentColor;
  border-bottom: 0;
  border-radius: 8rpx 8rpx 0 0;
}

.icon-more {
  width: 18rpx;
  height: 4rpx;
}

.icon-more::before {
  content: '';
  position: absolute;
  top: 0;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-more::before { left: 0; box-shadow: 7rpx 0 0 currentColor, 14rpx 0 0 currentColor; }

.icon-keyboard {
  width: 18rpx;
  height: 12rpx;
  border: 2.5rpx solid currentColor;
  border-radius: 3rpx;
}

.icon-keyboard::before {
  content: '';
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  top: 4rpx;
  height: 1.5rpx;
  background: currentColor;
  box-shadow: 0 3rpx 0 currentColor;
}

.icon-mic {
  width: 12rpx;
  height: 16rpx;
  border: 2.5rpx solid currentColor;
  border-radius: 6rpx;
}

.icon-mic::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 14rpx;
  width: 8rpx;
  height: 2.5rpx;
  background: currentColor;
  transform: translateX(-50%);
}

.icon-plus {
  width: 18rpx;
  height: 18rpx;
}

.icon-plus::before,
.icon-plus::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  background: currentColor;
  transform: translate(-50%, -50%);
}

.icon-plus::before { width: 18rpx; height: 3rpx; }
.icon-plus::after { width: 3rpx; height: 18rpx; }

.icon-close {
  width: 18rpx;
  height: 18rpx;
}

.icon-close::before,
.icon-close::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 18rpx;
  height: 3rpx;
  background: currentColor;
  transform-origin: center;
}

.icon-close::before { transform: translate(-50%, -50%) rotate(45deg); }
.icon-close::after { transform: translate(-50%, -50%) rotate(-45deg); }

.icon-image {
  width: 20rpx;
  height: 16rpx;
  border: 2.5rpx solid currentColor;
  border-radius: 3rpx;
}

.icon-image::before {
  content: '';
  position: absolute;
  left: 3rpx;
  bottom: 3rpx;
  width: 6rpx;
  height: 6rpx;
  border-left: 2.5rpx solid currentColor;
  border-top: 2.5rpx solid currentColor;
  transform: rotate(45deg);
}

.icon-image::after {
  content: '';
  position: absolute;
  right: 3rpx;
  bottom: 3rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-camera {
  width: 20rpx;
  height: 14rpx;
  border: 2.5rpx solid currentColor;
  border-radius: 4rpx;
}

.icon-camera::before {
  content: '';
  position: absolute;
  left: 4rpx;
  top: -5rpx;
  width: 5rpx;
  height: 3rpx;
  background: currentColor;
  border-radius: 2rpx;
}

.icon-camera::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 6rpx;
  height: 6rpx;
  border: 2.5rpx solid currentColor;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.icon-smile {
  width: 18rpx;
  height: 18rpx;
  border: 2.5rpx solid currentColor;
  border-radius: 50%;
}

.icon-smile::before {
  content: '';
  position: absolute;
  left: 4rpx;
  top: 5rpx;
  width: 2.5rpx;
  height: 2.5rpx;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 8rpx 0 0 currentColor;
}

.icon-smile::after {
  content: '';
  position: absolute;
  left: 4rpx;
  bottom: 4rpx;
  width: 10rpx;
  height: 5rpx;
  border-bottom: 2.5rpx solid currentColor;
  border-radius: 0 0 10rpx 10rpx;
}
