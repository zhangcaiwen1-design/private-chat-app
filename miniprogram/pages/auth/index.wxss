.auth-screen {
  min-height: 100vh;
  background: #ededed;
  box-sizing: border-box;
  padding: 32rpx 28rpx 40rpx;
}

.auth-header {
  padding: 28rpx 8rpx 20rpx;
}

.auth-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #111111;
}

.auth-content {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.auth-copy {
  color: #6b6b6b;
  font-size: 26rpx;
  line-height: 1.7;
  margin-bottom: 10rpx;
}

.auth-input {
  min-height: 92rpx;
  border-radius: 12rpx;
  background: #ffffff;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #111111;
}

.pin-note {
  color: #8c8c8c;
  font-size: 22rpx;
  line-height: 1.5;
  margin-top: -8rpx;
}

.placeholder {
  color: #9b9b9b;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 6rpx;
}

.agreement-text {
  flex: 1;
  color: #6b6b6b;
  font-size: 24rpx;
  line-height: 1.7;
}

.link {
  color: #07c160;
}

.error {
  color: #c34d3e;
  font-size: 24rpx;
}

.primary-button {
  margin-top: 8rpx;
  min-height: 92rpx;
  border-radius: 12rpx;
  background: #111111;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 92rpx;
}
