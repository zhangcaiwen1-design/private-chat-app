page {
  background: #ededed;
  color: #111111;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

button {
  margin: 0;
}

button::after {
  border: 0;
}

.screen {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #ededed;
}

.panel {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.muted {
  color: #8c8c8c;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.25;
}

.subtitle {
  color: #6b6b6b;
  line-height: 1.6;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 28rpx;
  border-radius: 12rpx;
  background: #111111;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border: 0;
  line-height: 1.2;
}

.btn.secondary {
  background: #f2f2f2;
  color: #111111;
}

.btn.warn {
  background: #c34d3e;
  color: #fff7ef;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.label {
  font-size: 24rpx;
  color: #6b6b6b;
  font-weight: 500;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  background: #fff;
  border: 1rpx solid #d7d7d7;
  border-radius: 12rpx;
  padding: 20rpx 22rpx;
  font-size: 28rpx;
  color: #111111;
}

.textarea {
  min-height: 160rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f2f2f2;
  color: #4a4a4a;
  font-size: 22rpx;
  font-weight: 600;
}

.divider {
  height: 1rpx;
  background: #e5e5e5;
  margin: 16rpx 0;
}

.empty {
  padding: 48rpx 24rpx;
  text-align: center;
  color: #7b6a5b;
}

.tiny {
  font-size: 22rpx;
}
