# Express server port
# Backend startup reads project root .env first, and also supports backend/.env.
PORT=3001
ADMIN_MEMBERSHIP_KEY=change-me-admin-key

# WeChat virtual payment config
WECHAT_MINIPROGRAM_APP_ID=change-me-appid
WECHAT_MINIPROGRAM_APP_SECRET=change-me-app-secret
WECHAT_VIRTUAL_PAY_OFFER_ID=change-me-offer-id
WECHAT_VIRTUAL_PAY_APP_KEY=change-me-app-key
WECHAT_VIRTUAL_PAY_ENV=0
WECHAT_VIRTUAL_PAY_CURRENCY=CNY
# Optional overrides per plan code:
# WECHAT_VIRTUAL_PAY_PRODUCT_FIRST_MONTH_19_9=product-id-1
# WECHAT_VIRTUAL_PAY_PRODUCT_MONTHLY_39_9=product-id-2
# WECHAT_VIRTUAL_PAY_PRODUCT_QUARTERLY_99=product-id-3
# WECHAT_VIRTUAL_PAY_PRODUCT_ANNUAL_299=product-id-4

# Optional SQLite database location.
# Relative paths are resolved from the process working directory.
# DB_PATH=./data/app.db
