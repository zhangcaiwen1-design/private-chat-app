# Server
PORT=3001
NODE_ENV=development

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Aliyun OSS (使用独立的Bucket避免冲突)
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=private-chat-app-oss
OSS_REGION=cn-hangzhou
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# Aliyun RDS MySQL (使用独立的数据库避免冲突)
RDS_HOST=rm-xxxxx.mysql.aliyuncs.com
RDS_PORT=3306
RDS_DB=private_chat_app
RDS_USER=your-db-user
RDS_PASSWORD=your-db-password

# SMS (Aliyun Dysms)
SMS_ACCESS_KEY_ID=your-access-key-id
SMS_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=私密聊天
SMS_TEMPLATE_CODE=SMS_xxxxx
