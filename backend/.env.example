# Server
PORT=3001
NODE_ENV=production

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Upload Directory (local storage)
UPLOAD_DIR=/home/admin/private-chat/uploads

# Aliyun RDS MySQL
RDS_HOST=rm-xxxxx.mysql.aliyuncs.com
RDS_PORT=3306
RDS_DB=private_chat_app
RDS_USER=your-db-user
RDS_PASSWORD=your-db-password
